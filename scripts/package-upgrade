#!/bin/bash
# DESC: Build, tag and push the harvester-upgrade image
set -e

TOP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"
SCRIPTS_DIR="${TOP_DIR}/scripts"
UPGRADE_DIR="${TOP_DIR}/package/upgrade"

# copy the addon manifests generated by the prepare-addons target
rm -rf "$UPGRADE_DIR/addons"
cp -r "$TOP_DIR/dist/prepare-addons/addons-manifests" "$UPGRADE_DIR/addons"

source $SCRIPTS_DIR/version

cd $UPGRADE_DIR

IMAGE=${REPO}/harvester-upgrade:${TAG}
DOCKERFILE=Dockerfile
if [ -e ${DOCKERFILE}.${ARCH} ]; then
    DOCKERFILE=${DOCKERFILE}.${ARCH}
fi

cp ../../bin/upgrade-helper .
cp ../../bin/harvester-installer .

BUILD_ARGS="--build-arg ARCH=${ARCH}"

docker build -f ${DOCKERFILE} ${BUILD_ARGS} -t ${IMAGE} .
echo Built ${IMAGE}

IMAGE_PUSH=${REPO}/harvester-upgrade:${IMAGE_PUSH_TAG}
docker tag "${IMAGE}" "${IMAGE_PUSH}"
echo Tagged "${IMAGE_PUSH}"

DOCKER_CONFIG="${TOP_DIR}/.docker"
if [[ -n ${PUSH} ]];then
  extra_args=""

  if [ -d "${DOCKER_CONFIG}" ]; then
    extra_args="--config=${DOCKER_CONFIG}"
  else
    echo "Docker config directory ${DOCKER_CONFIG} does not exist. Using default docker config."
  fi

  docker $extra_args push "${IMAGE_PUSH}"
  echo Pushed "${IMAGE_PUSH}"
fi
